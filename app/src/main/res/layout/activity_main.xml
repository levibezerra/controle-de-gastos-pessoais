<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/layoutPrincipal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtBoasVindas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, Bem Vindo!"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E293B"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Controle seus gastos de forma simples"
            android:textSize="16sp"
            android:textColor="#64748B"
            android:layout_marginBottom="20dp"/>

        <!-- Resumo Financeiro -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumo Financeiro"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtReceitas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Receitas: R$ 0,00"
                android:textSize="18sp"
                android:textColor="#16A34A"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtDespesas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Despesas: R$ 0,00"
                android:textSize="18sp"
                android:textColor="#DC2626"
                android:layout_marginTop="5dp"/>

            <TextView
                android:id="@+id/txtSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo: R$ 0,00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2563EB"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Meta -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meta de Economia"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meta: R$ 500"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtFaltam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Faltam: R$ 500"
                android:textSize="18sp"/>
        </LinearLayout>

        <!-- Botões -->

        <Button
            android:id="@+id/btnReceita"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="+ Adicionar Receita"
            android:textSize="18sp"
            android:layout_marginTop="25dp"/>

        <Button
            android:id="@+id/btnDespesa"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="+ Adicionar Despesa"
            android:textSize="18sp"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnRelatorio"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Relatórios"
            android:textSize="18sp"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnConfiguracoes"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Configurações"
            android:textSize="18sp"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>